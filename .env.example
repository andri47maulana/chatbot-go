# ============================================================
# WhatsApp Bot Go - Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---------- HTTP Server ----------
HTTP_ADDR=:9000

# ---------- Database (MySQL) ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aigri
DB_USER=root
DB_PASSWORD=secret
DB_MAX_OPEN=25
DB_MAX_IDLE=10
# Connection max lifetime in minutes
DB_CONN_LIFETIME=5

# ---------- Redis ----------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE=5

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...
# Default model; gpt-4o-mini is recommended for speed+cost
OPENAI_MODEL=gpt-4o-mini

# ---------- WAHA (WhatsApp HTTP API) ----------
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION=default
# Restart WAHA session automatically after N consecutive send failures
WAHA_AUTO_RESTART=true

# ---------- RAG Backend ----------
# Qdrant-backed RAG service
RAG_BACKEND_URL=http://localhost:5002
RAG_API_KEY=1245

# ---------- Bot Identity ----------
# Full phone number of the WhatsApp account running the bot (digits only, no +)
BOT_PHONE_NUMBER=6281234567890

# ---------- Worker Pool ----------
WORKER_COUNT=20
JOB_QUEUE_SIZE=500

# ---------- Deduplication ----------
# How long (minutes) to remember a processed message ID to reject duplicates
DEDUPE_WINDOW_MIN=5
